  "graphTooltip": 1,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "agentgrep"
      ],
      "title": "agentgrep dashboards",
      "type": "dashboards"
    }
